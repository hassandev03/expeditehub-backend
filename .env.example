PORT=5000

MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/expeditehub

# Note: double-s for TLS (Upstash)
REDIS_URL=rediss://<upstash-url>

ACCESS_TOKEN_SECRET=<random-256-bit-string>
REFRESH_TOKEN_SECRET=<different-random-256-bit-string>
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

NODE_ENV=development
